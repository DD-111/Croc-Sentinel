// ── Ethernet PHY (used when NETIF_MODE == NETIF_MODE_ETHERNET) ──
#ifndef ETH_PHY_TYPE
#ifdef BOARD_ETH_PHY_TYPE
#define ETH_PHY_TYPE BOARD_ETH_PHY_TYPE
#else
#define ETH_PHY_TYPE ETH_PHY_LAN8720
#endif
#endif
#ifndef ETH_PHY_ADDR
#ifdef BOARD_ETH_PHY_ADDR
