#ifndef CONFIG_H
#define CONFIG_H

// Template only — copy to `config.h` (see repo `.gitignore` / root build notes).
// Production: set PROD_ENFORCE to 1 and fill MQTT/OTA/bootstrap secrets to match
// `croc_sentinel_systems/.env`. Leave compile-time WIFI_* empty and use Dashboard
// `wifi_config` or factory NVS for STA credentials.

// Optional board overrides:
// #define FORCE_BOARD_PROFILE_PRODINO_ESP32_ETH
// #define FORCE_BOARD_PROFILE_WAVESHARE_ESP32_P4_ETH

#include "board_select.h"

// ── Firmware version (bump before each OTA release) ──
#define FW_VERSION "2.1.3"
// Production guardrails: set to 1 for strict startup validation (requires real secrets).
#define PROD_ENFORCE 0
// Keep command compatibility with previous 2 protocol versions.
#define CMD_PROTO_MIN 1
#define CMD_PROTO_MAX 2

// ── Device ID mode ──
#define DEVICE_ID_AUTO 1
#define DEVICE_ID_MANUAL "esp32-001"

// ── Zone ──
#define DEVICE_ZONE "all"

// ── WiFi ──
// Production: leave all empty — use NVS from Dashboard wifi_config or factory burn.
// Optional compile-time fallbacks for lab / bring-up only.
#define WIFI_SSID ""
#define WIFI_PASSWORD ""
#define WIFI_SSID_2 ""
#define WIFI_PASSWORD_2 ""
#define WIFI_SSID_3 ""
#define WIFI_PASSWORD_3 ""
#define WIFI_SSID_4 ""
#define WIFI_PASSWORD_4 ""
#define WIFI_CONNECT_WAIT_MS 8000
// One WiFiMulti::run slice (ms); used in setup, blocking join, and loop() link keepalive.
#ifndef WIFI_MULTI_RUN_SLICE_MS
#define WIFI_MULTI_RUN_SLICE_MS 200
#endif

// ── Network interface mode ──
// WIFI=1, ETHERNET=2, AUTO=3 (prefer Ethernet on ETH boards, fall back to WiFi).
// AUTO requires BOARD_HAS_ETH; on WiFi-only boards it collapses to WIFI.
#define NETIF_MODE_WIFI 1
#define NETIF_MODE_ETHERNET 2
#define NETIF_MODE_AUTO 3
#ifndef BOARD_HAS_ETH
#define BOARD_HAS_ETH 0
#endif
#ifndef NETIF_MODE
#ifdef BOARD_DEFAULT_NETIF_MODE
#define NETIF_MODE BOARD_DEFAULT_NETIF_MODE
#else
#define NETIF_MODE NETIF_MODE_AUTO
#endif
#endif
// Collapse AUTO to WIFI when the board has no Ethernet PHY.
#if NETIF_MODE == NETIF_MODE_AUTO && !BOARD_HAS_ETH
#undef NETIF_MODE
#define NETIF_MODE NETIF_MODE_WIFI
#endif

