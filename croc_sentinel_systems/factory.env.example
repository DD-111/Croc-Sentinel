# ── Factory-only env (copy → factory.env, never commit factory.env) ─────────
#
# Used by: tools/factory_pack/factory_ui.py, generate_serial_qr.py
# Default path: croc_sentinel_systems/factory.env  (see factory_core.default_dotenv_path)
#
# Put ONLY what manufacturing PCs need. Values MUST match the API container:
#   QR_SIGN_SECRET     — same as server croc_sentinel_systems/.env (docker api service)
#   FACTORY_API_TOKEN  — same as server FACTORY_API_TOKEN
#
# After copying from server, regenerate all serials/PNGs; old files keep old signatures.

QR_SIGN_SECRET=PASTE_SAME_VALUE_AS_SERVER_QR_SIGN_SECRET
FACTORY_API_TOKEN=PASTE_SAME_VALUE_AS_SERVER_FACTORY_API_TOKEN
