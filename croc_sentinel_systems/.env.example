MQTT_USERNAME=prod_mqtt_user
MQTT_PASSWORD=REPLACE_WITH_STRONG_MQTT_PASSWORD
BOOTSTRAP_MQTT_USERNAME=prod_bootstrap_user
BOOTSTRAP_MQTT_PASSWORD=REPLACE_WITH_STRONG_BOOTSTRAP_PASSWORD
CMD_AUTH_KEY=REPLACE_WITH_16_HEX_KEY
BOOTSTRAP_BIND_KEY=REPLACE_WITH_STRONG_BIND_KEY
CMD_PROTO=2
TOPIC_ROOT=sentinel
MQTT_HOST=mosquitto
MQTT_PORT=18962
# API paho client: TLS to broker (must match TLS listener on MQTT_PORT).
MQTT_USE_TLS=1
MQTT_CLIENT_CA=/etc/sentinel/mqtt-ca.crt
MQTT_TLS_CA_FILE=/mosquitto/certs/ca.crt
MQTT_TLS_CERT_FILE=/mosquitto/certs/server.crt
MQTT_TLS_KEY_FILE=/mosquitto/certs/server.key
MQTT_TLS_REQUIRE_CLIENT_CERT=false
API_TOKEN=REPLACE_WITH_LONG_RANDOM_API_TOKEN
# Must match config.h OTA_TOKEN (same string on ESP32 and in nginx OTA rule).
OTA_TOKEN=a3f9c2e81b704d65f0a8629c1d4e7b08
DB_PATH=/data/sentinel.db
LOG_FILE_PATH=/data/api.log
PROVISION_USE_SHARED_MQTT_CREDS=1
SCHEDULER_POLL_SECONDS=1.0
CLAIM_RESPONSE_INCLUDE_SECRETS=0
MAX_BULK_TARGETS=500
CACHE_TTL_SECONDS=2.0
MESSAGE_RETENTION_DAYS=14
ENFORCE_PER_DEVICE_CREDS=0
ENFORCE_DEVICE_CHALLENGE=0
DEVICE_CHALLENGE_TTL_SECONDS=300
DEVICE_ID_REGEX=^SN-[A-Z2-7]{16}$
QR_CODE_REGEX=^CROC\|SN-[A-Z2-7]{16}\|\d{10}\|[A-Za-z0-9_-]{20,120}$
QR_SIGN_SECRET=REPLACE_WITH_LONG_RANDOM_QR_SIGN_SECRET

# Legacy owner-less devices are accessible by any admin when = 1. Set to 0 after migration.
ALLOW_LEGACY_UNOWNED=1

# Where the console static UI is mounted under the API service. /ui and /dashboard auto-redirect here.
# Pick anything you like (e.g. /console, /app, /c, /manage). Default: /console
DASHBOARD_PATH=/console

# --- Dashboard users (JWT). First boot: if dashboard_users empty and password set, seeds one superadmin.
JWT_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARS_FOR_JWT_SIGNING
JWT_EXPIRE_SECONDS=28800
BOOTSTRAP_DASHBOARD_SUPERADMIN_USERNAME=superadmin
# Leave empty after first deploy if you do not want auto-seed on fresh DB.
BOOTSTRAP_DASHBOARD_SUPERADMIN_PASSWORD=

# --- Offline password recovery (RSA public on API, private.pem NEVER on server) ---
# Generate keys:  python password_recovery_offline/gen_rsa_keys.py
# Then set ONE of:
#PASSWORD_RECOVERY_PUBLIC_KEY_PATH=/etc/sentinel/password_recovery_public.pem
#PASSWORD_RECOVERY_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----"
# Inner JSON max size before AES padding (bytes). Default 512.
#PASSWORD_RECOVERY_PLAINTEXT_PAD=512
# Token lifetime for /auth/forgot/start (seconds). Default 86400 (24h).
#FORGOT_PASSWORD_TOKEN_TTL_SECONDS=86400
#FORGOT_PASSWORD_IP_WINDOW_SECONDS=3600
#FORGOT_PASSWORD_IP_MAX=12

# Encrypted DB backup: use header X-Backup-Encryption-Key (64 hex chars) on /admin/backup/* — not stored in .env.

# --- Server-side alarm fan-out (tenant-isolated siren mesh) ---
# When an ESP32 publishes alarm.trigger on its /event topic, the API verifies
# ownership and dispatches siren_on commands to all sibling devices under the
# SAME owner_admin. No MQTT broadcast topic is used, so admins never bleed
# into each other's devices.
ALARM_FANOUT_DURATION_MS=8000
ALARM_FANOUT_MAX_TARGETS=200
# 1 = also send siren_on back to the source device (belt-and-suspenders; the
#     device already triggered locally and de-dupes via nonce/ts).
ALARM_FANOUT_SELF=0

# --- Dashboard login brute-force protection (sliding window per IP + username) ---
LOGIN_RATE_MAX_FAILS=5
LOGIN_RATE_WINDOW_SECONDS=900

# --- Presence thresholds used by /dashboard/overview ---
OFFLINE_THRESHOLD_SECONDS=90

# --- OTA firmware hosting ---
# The API reads /ota/firmwares from this directory on disk. Drop signed .bin
# files here (e.g. via CI). SHA-256 is computed lazily and cached.
OTA_FIRMWARE_DIR=/opt/sentinel/firmware
# Public HTTPS base URL where the same directory is served as /fw/<name>.bin.
# Leave blank if you distribute firmware via a separate CDN / object store.
OTA_PUBLIC_BASE_URL=

# --- SMTP notifier (alarm → email) ---
# Leave SMTP_HOST blank to fully disable email notifications.
SMTP_HOST=
SMTP_PORT=587
# starttls | ssl | plain
SMTP_MODE=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TIMEOUT_SECONDS=15
SMTP_QUEUE_MAX=500
# Subject prefix prepended to every alarm notification.
SMTP_SUBJECT_PREFIX=[Sentinel]

# --- Public admin self-signup + email/SMS verification ---
# ALLOW_PUBLIC_ADMIN_SIGNUP=0 completely closes /auth/signup/start (private
# deployments where only superadmin provisions admins should set this to 0).
ALLOW_PUBLIC_ADMIN_SIGNUP=1
# If 1 (recommended) every new admin signup must pass email OTP AND be approved
# by a superadmin before they can log in. Set to 0 for demo / trusted lab use.
ADMIN_SIGNUP_REQUIRE_APPROVAL=1
REQUIRE_EMAIL_VERIFICATION=1
# Phone verification only works when SMS_PROVIDER is set to an implemented
# provider. Keep 0 in email-only deployments.
REQUIRE_PHONE_VERIFICATION=0
SMS_PROVIDER=none
OTP_TTL_SECONDS=900
OTP_RESEND_COOLDOWN_SECONDS=60
SIGNUP_RATE_MAX=5
SIGNUP_RATE_WINDOW_SECONDS=3600

# --- Factory device registry (unguessable serial model) ---
# When ENFORCE_FACTORY_REGISTRATION=1 the API refuses to enqueue a pending
# claim for any (serial, mac) that is not in factory_devices. This is the
# production default once you've wired up the factory provisioning pipeline.
ENFORCE_FACTORY_REGISTRATION=0
# Bearer token for factory-side bulk upload to /factory/devices. Keep long
# and random. Leave blank to require a superadmin JWT instead.
FACTORY_API_TOKEN=
# Optional: default API root for tools/factory_pack/factory_ui.py and
# generate_serial_qr.py --push (no trailing slash), e.g. https://your-vps:8088
FACTORY_UI_API_BASE=

# --- Presence probe (12h idle → server ping) ---
# Devices in EVENT heartbeat mode only publish state when something happens.
# After this many seconds of silence, the API emits a `ping` command and
# records the attempt in presence_probes. Default: 12h.
PRESENCE_PROBE_IDLE_SECONDS=43200
# How often to sweep device_state for stale rows.
PRESENCE_PROBE_SCAN_SECONDS=300
# Don't probe the same device twice within this window.
PRESENCE_PROBE_COOLDOWN_SECONDS=1800
# Stop probing a device after this many consecutive misses.
PRESENCE_PROBE_MAX_CONSECUTIVE=3

# --- OTA campaigns ---
# Timeout for the HEAD URL pre-flight check when an admin accepts a campaign.
OTA_URL_VERIFY_TIMEOUT_SECONDS=10
# How long we wait for ota.result from a device before giving up.
OTA_DEVICE_ACK_TIMEOUT_SECONDS=900
# If 1, any single device failure auto-rolls-back every already-upgraded
# device under the same admin. Set 0 to require manual rollback.
OTA_AUTO_ROLLBACK_ON_FAILURE=1

# --- Event center (unified realtime log) ---
# In-memory ring buffer size (one row ~ 500B). Default 2000 ≈ 1 MB.
EVENT_RING_SIZE=2000
# Per-SSE-subscriber queue. Slow client → oldest events dropped.
EVENT_SUB_QUEUE_SIZE=500
# Concurrent SSE subscriber cap. 128 @ ~250KB each ≈ 32 MB worst case.
EVENT_MAX_SUBSCRIBERS=128
# SSE keepalive comment interval (seconds). Browsers / proxies kill idle SSE.
EVENT_SSE_KEEPALIVE_SECONDS=20
# Level-based retention (days). debug rows go first; critical stays for audits.
EVENT_RETAIN_DAYS_DEBUG=3
EVENT_RETAIN_DAYS_INFO=14
EVENT_RETAIN_DAYS_WARN=30
EVENT_RETAIN_DAYS_ERROR=90
EVENT_RETAIN_DAYS_CRITICAL=365
# Absolute backstop — any event older than this is pruned regardless of level.
EVENT_RETAIN_DAYS_MAX=400
# How often the retention worker runs (seconds).
EVENT_RETENTION_SCAN_SECONDS=3600
